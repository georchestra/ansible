api:
  enabled: true
  address: 127.0.0.1:8686
sources:
  opentelemetry:
    type: opentelemetry
    grpc:
      address: {{ analytics.vector.ip }}:{{ analytics.vector.port }}
    http:
      address: 0.0.0.0:4318
      headers: []
      keepalive:
        max_connection_age_jitter_factor: 0.1
        max_connection_age_secs: 300
transforms:
  empty_resources:
    # Drop heavy resources field
    type: remap
    inputs:
      - opentelemetry.logs
    source: del(.resources)

  sp_access_logs_filter:
    # Accept only access logs from Security proxy
    type: filter
    inputs:
      - empty_resources
    condition:
      type: "vrl"
      # filter on url here, gateway does it in its logging config
      # XXX beware, .attributes."http.request.path" not .attributes.http.request.path
      source: .scope.name == "org.georchestra.security.accesslog" && match!(.attributes."http.request.path", r'.*/(ows|ogc|wms|wfs|wcs|wps)(/.*|\?.*)?$')
      # source: match!(.scope.name, r'org.georchestra.*.accesslog') 

  gw_access_logs_filter:
    # Accept only access logs from Gateway
    type: filter
    inputs:
      - opentelemetry.logs
    condition:
      type: "vrl"
      source: '.scope.name == "org.georchestra.gateway.accesslog" '
      # source: match!(.scope.name, r'org.georchestra.*.accesslog')

sinks:
  console:
    type: console
    # https://vector.dev/docs/reference/configuration/sinks/console/
    inputs:
      - gw_access_logs_filter
      - sp_access_logs_filter
      - opentelemetry.logs
    target: stdout
    encoding:
      codec: json
  tsdb:
    type: postgres
    # https://vector.dev/docs/reference/configuration/sinks/postgres/
    inputs:
      - gw_access_logs_filter
      - sp_access_logs_filter
    endpoint: "postgres://${TSDB_USER}:${TSDB_PASSWORD}@${TSDB_HOST}:${TSDB_PORT}/${TSDB_NAME}"
    table: "${TSDB_OTEL_TABLE:-analytics.opentelemetry_buffer}"
    pool_size: 5